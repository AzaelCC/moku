# Host port exposed by Docker Compose for Postgres.
MOKU_POSTGRES_PORT=5432

# Host port exposed by Docker Compose for the backend API.
MOKU_BACKEND_PORT=8000

# If you run the backend outside Docker Compose, this uses the host Postgres port above.
MOKU_DATABASE_URL=postgresql+asyncpg://moku:moku@localhost:${MOKU_POSTGRES_PORT}/moku
MOKU_APP_NAME=Moku Backend
MOKU_DEFAULT_CORPUS_NAME=sample-en
MOKU_DEFAULT_LANGUAGE=en
MOKU_DEFAULT_LEARNER_HANDLE=default
MOKU_ANKI_CONNECT_URL=http://127.0.0.1:8765
MOKU_ANKI_CONNECT_API_KEY=
MOKU_ANKI_CONNECT_TIMEOUT_SECONDS=10
MOKU_ANKI_CONNECT_BATCH_SIZE=500

# Optional Hugging Face token for gated datasets such as OpenSubtitles2024.
HF_TOKEN=
